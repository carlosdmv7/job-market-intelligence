# Copy to .env and fill in. Loaded by jmi_core.settings (pydantic-settings).
# The default stack is 0€: MotherDuck free tier + local Ollama + free public
# job APIs. The ONLY required secret is the MotherDuck token.

# === REQUIRED ==============================================================
# MotherDuck token (https://app.motherduck.com -> Settings -> Access Tokens).
motherduck_token=

# Which MotherDuck database to use (must already exist in the MotherDuck UI).
JMI_DUCKDB_DATABASE=md:job-market-intelligence
# For fully-local dev with no cloud at all, use a file instead:
# JMI_DUCKDB_DATABASE=data/job_market.duckdb

# === LLM (default: local Ollama, no key, no cost) ==========================
# Install Ollama (https://ollama.com) then: `ollama pull qwen2.5:7b`
JMI_LLM_PROVIDER=ollama
JMI_LLM_MODEL=qwen2.5:7b
JMI_OLLAMA_HOST=http://localhost:11434
# Laptop-friendly knobs: cap inference threads (0 = all cores; lower = cooler/quieter)
# and how long the model stays in RAM after a request (0 unloads now, 5m keeps it
# warm across a batch, -1 never unloads).
JMI_OLLAMA_NUM_THREAD=6
JMI_OLLAMA_KEEP_ALIVE=5m
JMI_ENRICHMENT_PROMPT_VERSION=enrich/v1
JMI_ENRICHMENT_BATCH_SIZE=50

# --- Alternative LLM providers (optional; only if you switch JMI_LLM_PROVIDER)
# Gemini free tier:  JMI_LLM_PROVIDER=gemini  JMI_LLM_MODEL=gemini-2.5-flash
# (note: gemini-2.0-flash has NO free tier on some accounts — use a 2.5 model)
# GEMINI_API_KEY=
# Anthropic (paid):  JMI_LLM_PROVIDER=anthropic  JMI_LLM_MODEL=claude-haiku-4-5
# ANTHROPIC_API_KEY=

# === Scraping ==============================================================
JMI_SCRAPE_MAX_POSTINGS=200

# --- Optional improvement-section sources (not needed for the 0€ default) ---
# Adzuna (free key, per-country search NL/ES/DE/...): https://developer.adzuna.com
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=
# Scrapfly (LinkedIn/Indeed via anti-bot proxy):
# SCRAPFLY_KEY=

# === Logging ===============================================================
JMI_LOG_LEVEL=INFO
JMI_LOG_JSON=false
